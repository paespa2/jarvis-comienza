{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "allowJs": true,
    "declaration": false
  },
  "include": [
    "src/server.ts",
    "src/integrations/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.tsx",
    "**/*.jsx",
    "src/core/**/*",
    "src/services/**/*",
    "src/components/**/*",
    "src/brain/**/*"
  ]
}
