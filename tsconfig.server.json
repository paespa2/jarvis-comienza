{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "noImplicitThis": false,
    "allowJs": true,
    "declaration": false,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "src/server.ts",
    "src/integrations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.tsx",
    "**/*.jsx",
    "src/core/**/*",
    "src/services/**/*",
    "src/components/**/*",
    "src/brain/**/*"
  ]
}
