# ═══════════════════════════════════════════════════════
#  JARVIS — Variables de Entorno
#  Copia este archivo a .env y rellena las API keys
# ═══════════════════════════════════════════════════════

# ── IA Cloud (al menos una requerida) ───────────────────
# Claude de Anthropic — RECOMENDADO (más potente, paga)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (Llama 3.3 70B) — Gratis con límites generosos
# Obtener en: https://console.groq.com/
GROQ_API_KEY=

# Gemini de Google — Gratis con límites
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Modelos (opcional, ya hay defaults razonables) ───────
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash

# ── Integraciones remotas opcionales ────────────────────
OPENCLAW_URL=
OPENCLAW_GATEWAY_TOKEN=
PAPERCLIP_URL=
PAPERCLIP_AGENT_API_KEY=

# ── Servidor ─────────────────────────────────────────────
PORT=8080

# ── Vault de Obsidian ────────────────────────────────────
VAULT_PATH=./.vault
