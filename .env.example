# HuggingFace API Token (get from https://huggingface.co/settings/tokens)
# Leave empty for public datasets only (slower, rate limited)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# HuggingFace Cache Configuration
MAX_CACHE_SIZE=536870912
HF_UPDATE_INTERVAL=604800000

# Railway Configuration
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_PATH=./jarvis.db

# GitHub (optional)
GITHUB_TOKEN=

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Anthropic API (optional)
ANTHROPIC_API_KEY=
