# HuggingFace API Token (get from https://huggingface.co/settings/tokens)
# Leave empty for public datasets only (slower, rate limited)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# HuggingFace Cache Configuration
MAX_CACHE_SIZE=536870912
HF_UPDATE_INTERVAL=604800000

# Railway Configuration
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_PATH=./jarvis.db

# GitHub (optional)
GITHUB_TOKEN=

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Anthropic API (optional)
ANTHROPIC_API_KEY=

# ========================================================================
# JARVIS AI PROVIDER (REQUERIDO para chat real - no mock)
# ========================================================================
# ollama | openrouter | mock
AI_PROVIDER=ollama

# Ollama (local, recomendado) — instala https://ollama.com/download
# Para 16GB RAM/6GB VRAM: gemma3:1b (rápido) o gemma3:4b (mejor calidad)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# OpenRouter (cloud, opcional) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-1b-it:free
