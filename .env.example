# ========================================================================
# JARVIS v2.0 CONFIGURATION
# ========================================================================

# AI PROVIDER (REQUIRED)
# Options: lmstudio (recommended) | ollama | openrouter | mock
AI_PROVIDER=lmstudio

# ────────────────────────────────────────────────────────────────────────
# LM STUDIO (RECOMMENDED - Local, OpenAI-compatible API)
# ────────────────────────────────────────────────────────────────────────
# Install from: https://lmstudio.ai
# 1. Open LM Studio
# 2. Download a model (recommended: qwen/qwen3.5-9b - vision + tool use + 262K context)
# 3. Go to "Developer" tab → Click "Start Server"
# 4. Server runs on http://localhost:1234 by default

LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b

# Alternative models that work well with LM Studio:
# - qwen/qwen3.5-9b         (9B, vision, tools, 262K ctx) — RECOMMENDED
# - qwen/qwen2.5-coder-14b  (code specialist)
# - meta-llama/llama-3.3-8b (general purpose)
# - mistralai/mistral-small (good for security tasks)

# ────────────────────────────────────────────────────────────────────────
# OLLAMA (Fallback - Local)
# ────────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# ────────────────────────────────────────────────────────────────────────
# OPENROUTER (Cloud fallback - requires API key)
# ────────────────────────────────────────────────────────────────────────
# Get free API key from: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# ────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ────────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# DATABASE
DATABASE_PATH=./jarvis.db

# VAULT (Obsidian Knowledge Base)
VAULT_PATH=./.vault

# ========================================================================
# NOTES:
# - AI_PROVIDER=lmstudio: LM Studio must be running with server enabled
# - No external APIs required when using LM Studio (100% local & private)
# - Qwen3.5 9B recommended for GPUs with 6-8GB VRAM (partial offload)
# - Knowledge persists in .vault/ directory (Obsidian format)
# - Skills execute autonomously based on JARVIS reasoning
# ========================================================================
