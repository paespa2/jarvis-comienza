# ============================================
# Jarvis IA - Configuración del Motor Autónomo
# ============================================

# API de Gemini (Cerebro principal de Jarvis IA)
# Necesaria para que Jarvis procese lenguaje y ejecute herramientas.
# Obtener en: https://aistudio.google.com/apikey
JARVIS_GEMINI_API_KEY="tu_api_key_de_gemini"

# API de OpenRouter (Cerebro alternativo)
# Permite usar otros modelos (Llama, Mistral, etc.) como fallback.
# Obtener en: https://openrouter.ai/keys
JARVIS_OPENROUTER_API_KEY="tu_api_key_de_openrouter"

# Modelo principal de Jarvis IA
# Por defecto usa Gemini, pero puedes cambiarlo.
# Opciones: gemini-3-flash-preview, gemini-pro, etc.
JARVIS_MODEL="gemini-3-flash-preview"

# Modelo local alternativo (Ollama / LM Studio)
# Para funcionamiento 100% offline sin restricciones.
# Ejemplos: llama3.2, qwen2.5, deepseek-r1
JARVIS_LOCAL_MODEL="llama3.2"

# URL del servidor local de IA (Ollama / LM Studio)
# Deja vacío para usar solo Gemini.
JARVIS_LOCAL_API_URL="http://127.0.0.1:11434"

# Motor de IA a usar por defecto
# Opciones: gemini, local, openrouter, auto
# "auto" = usa Gemini si hay API key, si no usa local
JARVIS_ENGINE="auto"

# Temperatura del cerebro de Jarvis (0.0 - 1.0)
# 0.3 = más preciso y lógico
# 0.7 = más creativo y proactivo (recomendado)
# 1.0 = máxima creatividad
JARVIS_TEMPERATURE="0.7"

# Máximo de tokens de salida por respuesta
# Más tokens = respuestas más largas y completas
JARVIS_MAX_TOKENS="8192"

# Modo autónomo de Jarvis IA
# true = ejecuta herramientas sin pedir confirmación
# false = pide confirmación antes de ejecutar
JARVIS_AUTO_EXECUTE="true"

# ============================================
# Configuración del Servidor
# ============================================

# URL donde corre Jarvis IA
# Usualmente http://localhost:3000 en desarrollo
JARVIS_APP_URL="http://localhost:3000"

# Puerto del servidor
JARVIS_PORT="3000"

# ============================================
# Directorio de Trabajo
# ============================================

# Directorio donde Jarvis ejecuta comandos y gestiona archivos
# Por defecto: jarvis_workspace dentro del proyecto
JARVIS_WORKSPACE_DIR="jarvis_workspace"

# ============================================
# Modo Debug
# ============================================

# true = muestra logs detallados del motor
# false = solo muestra errores
JARVIS_DEBUG="false"
