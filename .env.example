# ========================================================================
# JARVIS v2.0 CONFIGURATION
# ========================================================================

# AI PROVIDER (REQUIRED)
# Options: ollama (local) | openrouter (cloud) | mock (fallback)
AI_PROVIDER=ollama

# OLLAMA (Local AI) - Recommended
# Install from: https://ollama.com/download
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# OPENROUTER (Cloud AI) - Optional fallback
# Get API key from: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-1b-it:free

# SERVER CONFIGURATION
PORT=3000
HOST=0.0.0.0

# DATABASE
DATABASE_PATH=./jarvis.db

# VAULT (Obsidian Knowledge Base)
VAULT_PATH=./.vault

# ========================================================================
# NOTES:
# - AI_PROVIDER=ollama: Requires Ollama running locally (ollama serve)
# - No external APIs required for local operation
# - Knowledge persists in .vault/ directory (Obsidian format)
# - Skills execute autonomously based on JARVIS reasoning
# ========================================================================
