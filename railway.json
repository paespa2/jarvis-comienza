{
  "$schema": "https://railway.app/v1.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "NODE_ENV=production npm run start",
    "port": 8080,
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
