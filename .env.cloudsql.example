# Cloud SQL Configuration for Jarvis
# Copy to .env and fill in your actual values

# ============================================
# CLOUD SQL CONNECTION (PostgreSQL)
# ============================================

# Direct Connection (Local Development)
CLOUD_SQL_HOST=127.0.0.1
CLOUD_SQL_PORT=5432
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=your_secure_password_here
CLOUD_SQL_DATABASE=asistente-jarvis-1741893602789-database
CLOUD_SQL_SSL=false

# OR Cloud SQL Auth Proxy (Recommended for Production)
# CLOUD_SQL_HOST=127.0.0.1
# CLOUD_SQL_PORT=5432
# CLOUD_SQL_INSTANCE=asistente-jarvis-1741893602789-instance:us-east4
# CLOUD_SQL_USER=postgres
# CLOUD_SQL_PASSWORD=your_secure_password_here

# ============================================
# FIREBASE (Optional - Fallback)
# ============================================

# Keep Firebase config for backward compatibility
# FIREBASE_CONFIG_PATH=./firebase-applet-config.json

# ============================================
# DEPLOYMENT
# ============================================

# Railroad/Railway Settings
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# GitHub (for auto-commits of improvements)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=paespa2
GITHUB_REPO=jarvis-comienza
GITHUB_BRANCH=main

# Self-Improve Endpoint
JARVIS_API_URL=https://your-railway-instance.up.railway.app
JARVIS_TOKEN=your_api_token_here

# ============================================
# NOTES
# ============================================

# For Railway Deployment:
# 1. Set these as Railway environment variables
# 2. Cloud SQL Auth Proxy will run in init script
# 3. Migrations run automatically on startup

# For Local Development:
# 1. Ensure PostgreSQL is running
# 2. Set CLOUD_SQL_HOST=localhost
# 3. Run: npm run build && npm start

# Password Policy:
# - Minimum 8 characters
# - Include uppercase, lowercase, numbers
# - Use special characters for security
