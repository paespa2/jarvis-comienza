{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Información del usuario y preferencias de Jarvis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "preferences": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Memory": {
      "title": "Jarvis Memory",
      "description": "Aprendizajes y datos recolectados del día a día.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["habit", "preference", "task", "observation"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "content", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "Tareas y recordatorios organizados por Jarvis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfiles de usuario."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Memoria persistente de Jarvis para cada usuario."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tareas gestionadas por Jarvis."
    }
  }
}
