{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Información del usuario y preferencias de Jarvis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "preferences": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Memory": {
      "title": "Jarvis Memory",
      "description": "Aprendizajes, historial de chat y datos recolectados del día a día.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["chat", "thought", "action", "evolution", "system"] },
        "role": { "type": "string", "enum": ["user", "jarvis"] },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "content", "type", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "Tareas y recordatorios organizados por Jarvis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "status"]
    },
    "KnowledgeNode": {
      "title": "Knowledge Node",
      "description": "Nodos de la memoria semántica de grafos de Jarvis (estilo Obsidian).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string", "description": "El concepto principal o entidad (ej: Proyecto Alpha, Juan)" },
        "content": { "type": "string", "description": "La información detallada sobre este nodo" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "links": { "type": "array", "items": { "type": "string" }, "description": "Títulos de otros nodos relacionados" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "title", "content", "updatedAt"]
    },
    "Genome": {
      "title": "Agent Genome",
      "description": "Represents the genetic state of the Jarvis AI agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "mutationVector": {
          "type": "object",
          "properties": {
            "aggressiveness": { "type": "number" },
            "caution": { "type": "number" },
            "predictivity": { "type": "number" }
          }
        },
        "mutation": { "type": "string" },
        "fitnessScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "parentId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "ARCHIVED", "MUTATED"] }
      }
    },
    "Decision": {
      "title": "Jarvis Decision",
      "description": "A record of a loyalty-based decision made by Jarvis.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "proposedAction": { "type": "string" },
        "loyaltyEvaluation": { "type": "object" },
        "result": { "type": "string", "enum": ["executed", "rejected", "mutated"] },
        "outcome": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfiles de usuario."
    },
    "/users/{userId}/knowledge_nodes/{nodeId}": {
      "schema": "KnowledgeNode",
      "description": "Nodos del grafo de conocimiento de Jarvis."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Memoria persistente de Jarvis para cada usuario."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tareas gestionadas por Jarvis."
    },
    "/jarvis/lineage/{generationId}": {
      "schema": "Genome",
      "description": "The evolutionary genealogy of Jarvis."
    }
  }
}
