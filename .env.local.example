# JARVIS LOCAL ENVIRONMENT VARIABLES - SECURE TEMPLATE
#
# FOR LOCAL DEVELOPMENT ONLY
# This file is .gitignored - keep it secret!
#
# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in your actual credential values
# 3. NEVER commit .env.local to git
# 4. NEVER share credentials in chat/email/messages

# ========================================
# FIREBASE FIRESTORE (REQUIRED)
# ========================================
# How to get:
# 1. Go: https://console.firebase.google.com/u/0/project/asistente-jarvis-1741893602789/settings/serviceaccounts/adminsdk
# 2. Click "Generate New Private Key"
# 3. Open the downloaded JSON file
# 4. Paste the ENTIRE contents here (keep in one line for .env)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"asistente-jarvis-1741893602789","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ========================================
# GITHUB INTEGRATION (REQUIRED for auto-commits)
# ========================================
# How to get GitHub token:
# 1. Go: https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Select scope: repo (full control of repos)
# 4. Expiration: 90 days
# 5. Click "Generate token"
# 6. Copy the token (starts with ghp_)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# GitHub configuration
GITHUB_OWNER=paespa2
GITHUB_REPO=jarvis-comienza
GITHUB_BRANCH=claude/jarvis-autonomous-testing-FlgyW

# ========================================
# CLOUD SQL (Optional - PostgreSQL fallback)
# ========================================
# Use if you want redundancy with Cloud SQL

# Cloud SQL instance IP (get from: https://console.cloud.google.com/sql/instances)
CLOUD_SQL_HOST=127.0.0.1

# PostgreSQL credentials
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=YOUR_CLOUD_SQL_PASSWORD_HERE
CLOUD_SQL_DATABASE=asistente-jarvis-1741893602789-database
CLOUD_SQL_SSL=true

# ========================================
# FIREBASE SQL CONNECT (Optional - GraphQL fallback)
# ========================================
# Use if you want GraphQL API to Firebase SQL Connect

FIREBASE_PROJECT_ID=asistente-jarvis-1741893602789
FIREBASE_SERVICE_ID=asistente-jarvis-1741893602789-service
FIREBASE_LOCATION=us-east4
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ========================================
# LOGGING (Optional)
# ========================================
LOG_LEVEL=debug

# ========================================
# SECURITY REMINDERS
# ========================================
# - NEVER commit this file to git
# - NEVER share credentials in chat/email/Slack
# - NEVER hardcode credentials in source code
# - Rotate tokens regularly (every 90 days)
# - Use .gitignore to exclude this file
# - For production, use Railway Secrets instead
